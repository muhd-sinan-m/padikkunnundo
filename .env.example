# ── Application ──────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string

# ── Development Mode ────────────────────────────────────────────────────────────
# Set to 'true' to bypass authentication (auto-creates a dev user).
# Only use this for local development. Set to 'false' or remove for production.
DEV_BYPASS_AUTH=false

# ── Database ──────────────────────────────────────────────────────────────────
# For local development, SQLite is used by default.
# For production (AWS RDS), replace with a PostgreSQL URL:
# DATABASE_URL=postgresql://username:password@host:5432/padikkunnundo
DATABASE_URL=sqlite:///padikkunnundo.db

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Obtain from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── College Configuration ─────────────────────────────────────────────────────
# Only Google accounts on this domain are permitted to sign in.
COLLEGE_DOMAIN=mariancollege.org

# ── Rate Limiting ──────────────────────────────────────────────────────────────
# Set to 'false' to disable rate limiting (not recommended for production).
RATELIMIT_ENABLED=true
# Storage backend for rate limiter (memory:// for development, redis://... for production)
RATELIMIT_STORAGE_URL=memory://

# ── Email Configuration (Resend API for password reset) ───────────────────────
# Get your API key from: https://resend.com/api-keys
# Make sure to verify your domain in Resend (e.g., padikkunnundo.app)
RESEND_API_KEY=re_your-resend-api-key
MAIL_FROM=noreply@padikkunnundo.app

# Password reset token expiry in seconds (default: 1 hour)
RESET_TOKEN_EXPIRY_SECONDS=3600
