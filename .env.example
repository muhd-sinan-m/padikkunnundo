# ── Application ──────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
# For local development, SQLite is used by default.
# For production (AWS RDS), replace with a PostgreSQL URL:
# DATABASE_URL=postgresql://username:password@host:5432/padikkunnundo
DATABASE_URL=sqlite:///padikkunnundo.db

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Obtain from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── College Configuration ─────────────────────────────────────────────────────
# Only Google accounts on this domain are permitted to sign in.
COLLEGE_DOMAIN=mariancollege.org
